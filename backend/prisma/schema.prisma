generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  passwordHash     String
  name             String?
  isAdmin          Boolean          @default(false)
  createdAt        DateTime         @default(now())
  monthlyIncome    Decimal?         @db.Decimal(12, 2)
  transactions     Transaction[]
  categories       Category[]
  budgets          Budget[]
  monthlySummaries MonthlySummary[]
  aiInsights       AIInsight[]
  revokedTokens    RevokedToken[]
}

model Category {
  id           String        @id @default(cuid())
  name         String
  color        String? // hex
  icon         String?
  user         User?         @relation(fields: [userId], references: [id])
  userId       String?
  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String?
  date        DateTime
  user        User            @relation(fields: [userId], references: [id])
  userId      String
  category    Category        @relation(fields: [categoryId], references: [id])
  categoryId  String

  @@index([userId, date])
  @@index([categoryId])
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Budget {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
  amount     Decimal  @db.Decimal(12, 2) // monthly limit
  month      Int? // 1-12 (optional, if null it's recurring monthly)
  year       Int? // optional
  createdAt  DateTime @default(now())

  @@index([userId, categoryId])
}

model MonthlySummary {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  year         Int
  month        Int
  totalIncome  Decimal  @db.Decimal(14, 2)
  totalExpense Decimal  @db.Decimal(14, 2)
  createdAt    DateTime @default(now())

  @@unique([userId, year, month])
  @@index([userId, year, month])
}

model AIInsight {
  id        String          @id @default(cuid())
  user      User            @relation(fields: [userId], references: [id])
  userId    String
  title     String
  message   String
  priority  InsightPriority
  meta      Json?
  createdAt DateTime        @default(now())

  @@index([userId, priority])
}

enum InsightPriority {
  HIGH
  MEDIUM
  LOW
}

model RevokedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}
